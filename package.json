{
  "name": "dronz-gooder-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @dronz-gooder/web & npm run dev --workspace @dronz-gooder/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier . --write",
    "db:generate": "npm run db:generate --workspace @dronz-gooder/api",
    "db:migrate": "npm run db:migrate --workspace @dronz-gooder/api",
    "db:seed": "npm run db:seed --workspace @dronz-gooder/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.6.2",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3"
  }
}
