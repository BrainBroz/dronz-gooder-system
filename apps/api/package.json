{
  "name": "@dronz-gooder/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --out-dir dist --dts",
    "test": "npm run db:test:prepare && vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:test:prepare": "bash ../../scripts/prepare-test-db.sh",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  }
}
