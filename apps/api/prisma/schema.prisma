generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Loja {
  id        String   @id @default(cuid())
  slug      String   @unique
  nome      String
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios                      UsuarioLoja[]
  categorias                    Categoria[]
  produtos                      Produto[]
  fornecedores                  Fornecedor[]
  pedidosCompra                 PedidoCompra[]
  pedidoCompraItens             PedidoCompraItem[]
  viajantes                     Viajante[]
  viagens                       Viagem[]
  malas                         Mala[]
  volumesLogisticos             VolumeLogistico[]
  alocacoesMala                 AlocacaoMala[]
  recebimentosMiami             RecebimentoMiami[]
  checkpointsParaguai           CheckpointParaguai[]
  checkpointsBrasil             CheckpointBrasil[]
  recebimentos                  Recebimento[]
  recebimentoItens              RecebimentoItem[]
  estoques                      Estoque[]
  estoquesEntradas              EstoqueEntrada[]
  movimentacoesEstoque          MovimentacaoEstoque[]
  cotacoesCambio                CotacaoCambio[]
  despesas                      Despesa[]
  pagamentos                    Pagamento[]
  custosPedido                  CustoPedido[]
  simulacoesViagem              SimulacaoViagem[]
  atribuicoes                   AtribuicaoItem[]
  comprasImportadas             CompraImportada[]
  atribuicoesCompraExterna      AtribuicaoCompraItem[]
  mapeamentosProdutoExterno     MapeamentoItemProduto[]
  mapeamentosMerchantFornecedor MapeamentoMerchantFornecedor[]
  materializacoesCompra         MaterializacaoCompra[]
}

model Usuario {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lojas                          UsuarioLoja[]
  perfis                         UsuarioPerfil[]
  refreshTokens                  RefreshToken[]
  auditLogs                      AuditLog[]
  eventosCorretivos              EventoCorretivo[]
  recebimentosMiami              RecebimentoMiami[]
  checkpointsParaguai            CheckpointParaguai[]
  checkpointsBrasil              CheckpointBrasil[]
  estoquesEntradas               EstoqueEntrada[]
  recebimentosConfirmados        Recebimento[]
  movimentacoesEstoque           MovimentacaoEstoque[]
  cotacoesCambio                 CotacaoCambio[]
  simulacoesViagemCriadas        SimulacaoViagem[]
  atribuicoes                    AtribuicaoItem[]
  contasExternasCriadas          ContaExterna[]
  mapeamentosProdutoRevisados    MapeamentoItemProduto[]
  mapeamentosFornecedorRevisados MapeamentoMerchantFornecedor[]
  atribuicoesCompraExterna       AtribuicaoCompraItem[]
  materializacoesCompra          MaterializacaoCompra[]
  conflitosCompraResolvidos      ConflitoCompra[]
}

model Perfil {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios   UsuarioPerfil[]
  permissoes PerfilPermissao[]
}

model Permissao {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  perfis PerfilPermissao[]
}

model UsuarioLoja {
  id        String   @id @default(cuid())
  usuarioId String
  lojaId    String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  loja    Loja    @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, lojaId])
  @@index([lojaId])
}

model UsuarioPerfil {
  id        String   @id @default(cuid())
  usuarioId String
  perfilId  String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  perfil  Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, perfilId])
  @@index([perfilId])
}

model PerfilPermissao {
  id          String   @id @default(cuid())
  perfilId    String
  permissaoId String
  createdAt   DateTime @default(now())

  perfil    Perfil    @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@unique([perfilId, permissaoId])
  @@index([permissaoId])
}

model RefreshToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  usuarioId    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([revokedAt])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  usuarioId      String?
  action         String
  entity         String
  entityId       String?
  data           Json?
  lojaId         String?
  permissionCode String?
  correlationId  String?
  idempotencyKey String?
  reason         String?
  beforeData     Json?
  afterData      Json?
  origin         String?
  createdAt      DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entity])
  @@index([usuarioId])
  @@index([lojaId, createdAt])
  @@index([correlationId])
}

model IdempotencyRecord {
  id             String   @id @default(cuid())
  lojaId         String
  operation      String
  entityId       String
  idempotencyKey String
  requestHash    String
  responseData   Json
  createdAt      DateTime @default(now())

  @@unique([lojaId, operation, entityId, idempotencyKey])
  @@index([lojaId, createdAt])
}

model EventoCorretivo {
  id              String                  @id @default(cuid())
  lojaId          String
  entity          String
  entityId        String
  originalEventId String
  correctionType  TipoCorrecaoOperacional
  reason          String
  beforeData      Json
  afterData       Json
  correlationId   String
  permissionCode  String
  usuarioId       String
  createdAt       DateTime                @default(now())
  usuario         Usuario                 @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([lojaId, entity, entityId, createdAt])
  @@index([originalEventId])
  @@index([correlationId])
}

enum TipoCorrecaoOperacional {
  DIVERGENCIA
  AJUSTE_RECEBIMENTO
  STOCK_COMPENSATION
}

model ProjecaoOperacional {
  id        String   @id @default(cuid())
  lojaId    String
  entity    String
  entityId  String
  state     Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([lojaId, entity, entityId])
  @@index([lojaId, entity, updatedAt])
}

model Categoria {
  id        String   @id @default(cuid())
  lojaId    String
  nome      String
  slug      String
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loja     Loja      @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  produtos Produto[]

  @@unique([lojaId, slug])
  @@unique([id, lojaId])
  @@index([lojaId])
  @@index([lojaId, ativo])
}

model Produto {
  id          String   @id @default(cuid())
  codigo      Int      @unique
  lojaId      String
  categoriaId String
  nome        String
  slug        String
  descricao   String?
  precoVenda  Decimal  @db.Decimal(10, 2)
  markup      Decimal  @db.Decimal(5, 2)
  peso        Decimal? @db.Decimal(10, 3)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loja                 Loja                    @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  categoria            Categoria               @relation(fields: [categoriaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  pedidoCompraItens    PedidoCompraItem[]
  estoques             Estoque[]
  recebimentoItens     RecebimentoItem[]
  movimentacoesEstoque MovimentacaoEstoque[]
  mapeamentosExternos  MapeamentoItemProduto[]

  @@unique([lojaId, slug])
  @@unique([id, lojaId])
  @@index([lojaId])
  @@index([lojaId, categoriaId])
  @@index([lojaId, ativo])
}

enum PedidoCompraStatus {
  DRAFT
  PLACED
  CONFIRMED
  PARTIALLY_RECEIVED_MIAMI
  RECEIVED_MIAMI
  ALLOCATED_TO_TRIP
  IN_TRANSIT_BRAZIL
  ARRIVED_BRAZIL
  COMPLETED
  CANCELLED
}

model Fornecedor {
  id                  String                         @id @default(cuid())
  lojaId              String
  nome                String
  nomeFantasia        String?
  site                String?
  email               String?
  telefone            String?
  pais                String?
  moedaPadrao         String?
  observacoes         String?
  ativo               Boolean                        @default(true)
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  loja                Loja                           @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  pedidosCompra       PedidoCompra[]
  mapeamentosExternos MapeamentoMerchantFornecedor[]

  @@unique([id, lojaId])
  @@index([lojaId, ativo])
  @@index([lojaId, nome])
}

enum StatusAtribuicao {
  PENDENTE_ATRIBUICAO
  PARCIALMENTE_ATRIBUIDA
  ATRIBUIDA
  IGNORADA
  DUPLICADA
}

enum PlataformaCompraExterna {
  AMAZON
  EBAY
  WALMART
  BEST_BUY
  APPLE
  OUTRA
  MANUAL
  LEGACY_REVIEW
}

enum OrigemCompraExterna {
  API
  IMPORTACAO_ARQUIVO
  MANUAL
  LEGACY
}

enum StatusContaExterna {
  ATIVA
  INATIVA
}

enum StatusMerchantExterno {
  ATIVO
  INATIVO
  EM_REVISAO
}

enum EstadoCompraImportada {
  IMPORTADA
  EM_REVISAO
  CANCELADA
  COM_DIVERGENCIA
}

enum EstrategiaIdentidadeLinha {
  EXTERNAL_LINE_ID
  FINGERPRINT
  LEGACY_REVIEW
}

enum StatusLinhaExterna {
  ATIVA
  CANCELADA
  COM_DIVERGENCIA
}

enum OrigemMapeamentoExterno {
  MANUAL
  IMPORTADO
}

enum StatusMapeamentoExterno {
  ATIVO
  INATIVO
}

enum StatusMaterializacaoCompra {
  CONCLUIDA
  BLOQUEADA
}

enum TipoConflitoCompra {
  QUANTITY_REDUCED_AFTER_ASSIGNMENT
  QUANTITY_REDUCED_AFTER_MATERIALIZATION
  EXTERNAL_ID_COLLISION
  MAPPING_CHANGED_AFTER_MATERIALIZATION
  DUPLICATE_EXTERNAL_ORDER
  STORE_ASSIGNMENT_OVERFLOW
  PRODUCT_NOT_FOUND
  PRODUCT_STORE_MISMATCH
  PAYLOAD_MISMATCH
  IDEMPOTENCY_CONFLICT
}

enum StatusConflitoCompra {
  ABERTO
  RESOLVIDO
}

model ContaExterna {
  id                      String                  @id @default(cuid())
  plataforma              PlataformaCompraExterna
  identificadorExterno    String
  nomeExibicao            String
  status                  StatusContaExterna      @default(ATIVA)
  origemIntegracao        OrigemCompraExterna
  metadata                Json?
  ultimaSincronizacaoEm   DateTime?
  ultimoErroSincronizacao String?
  criadoPorId             String
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  criadoPor Usuario           @relation(fields: [criadoPorId], references: [id], onDelete: Restrict)
  compras   CompraImportada[]

  @@unique([plataforma, identificadorExterno])
  @@index([status, plataforma])
}

model MerchantExterno {
  id                 String                  @id @default(cuid())
  plataforma         PlataformaCompraExterna
  externalMerchantId String?
  nomeOriginal       String
  nomeNormalizado    String
  status             StatusMerchantExterno   @default(ATIVO)
  metadata           Json?
  aliases            String[]                @default([])
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  compras     CompraImportada[]
  itens       CompraImportadaItem[]
  mapeamentos MapeamentoMerchantFornecedor[]

  @@unique([plataforma, externalMerchantId])
  @@index([plataforma, nomeNormalizado])
  @@index([status])
}

model CompraImportada {
  id                         String                  @id @default(cuid())
  lojaId                     String?
  fornecedorId               String?
  numeroPedido               String
  quantidade                 Int
  moeda                      String                  @default("USD")
  statusAtribuicao           StatusAtribuicao        @default(PENDENTE_ATRIBUICAO)
  observacao                 String?
  importadaEm                DateTime                @default(now())
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  plataforma                 PlataformaCompraExterna @default(LEGACY_REVIEW)
  contaExternaId             String?
  merchantExternoId          String?
  externalOrderIdOriginal    String?
  externalOrderIdNormalizado String?
  referenciaPesquisavel      String?
  dataPedido                 DateTime?
  statusExterno              String?
  totalExterno               Decimal?                @db.Decimal(14, 2)
  payloadSnapshot            Json?
  payloadHash                String?
  origem                     OrigemCompraExterna     @default(LEGACY)
  estado                     EstadoCompraImportada   @default(EM_REVISAO)
  version                    Int                     @default(1)
  ultimaSincronizacaoEm      DateTime?

  loja                Loja?                  @relation(fields: [lojaId], references: [id], onDelete: SetNull)
  itens               CompraImportadaItem[]  @relation("compraImportadaItens")
  atribuicoes         AtribuicaoItem[]
  pedidosOperacionais PedidoCompra[]
  contaExterna        ContaExterna?          @relation(fields: [contaExternaId], references: [id], onDelete: Restrict)
  merchantExterno     MerchantExterno?       @relation(fields: [merchantExternoId], references: [id], onDelete: Restrict)
  materializacoes     MaterializacaoCompra[]
  conflitos           ConflitoCompra[]

  @@unique([fornecedorId, numeroPedido])
  @@unique([plataforma, contaExternaId, externalOrderIdNormalizado])
  @@index([statusAtribuicao])
  @@index([importadaEm])
  @@index([lojaId])
  @@index([plataforma, importadaEm])
  @@index([contaExternaId, importadaEm])
  @@index([merchantExternoId, importadaEm])
  @@index([estado, importadaEm])
  @@index([referenciaPesquisavel])
}

model CompraImportadaItem {
  id                        String                    @id @default(cuid())
  compraImportadaId         String
  quantidade                Int
  observacao                String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  externalLineIdOriginal    String?
  externalLineIdNormalizado String?
  identityFingerprint       String
  identityDiscriminator     Int                       @default(0)
  identityStrategy          EstrategiaIdentidadeLinha
  identityVersion           Int                       @default(1)
  titulo                    String
  variacao                  String?
  skuExterno                String?
  asin                      String?
  identificadorOferta       String?
  precoUnitario             Decimal                   @db.Decimal(14, 2)
  moeda                     String                    @default("USD")
  quantidadeCancelada       Int                       @default(0)
  quantidadeReembolsada     Int                       @default(0)
  merchantExternoId         String?
  payloadSnapshot           Json?
  status                    StatusLinhaExterna        @default(ATIVA)
  version                   Int                       @default(1)

  compraImportada     CompraImportada            @relation("compraImportadaItens", fields: [compraImportadaId], references: [id], onDelete: Cascade)
  merchantExterno     MerchantExterno?           @relation(fields: [merchantExternoId], references: [id], onDelete: Restrict)
  mapeamentos         MapeamentoItemProduto[]
  atribuicoes         AtribuicaoCompraItem[]
  itensMaterializados MaterializacaoCompraItem[]
  conflitos           ConflitoCompra[]

  @@unique([compraImportadaId, externalLineIdNormalizado])
  @@unique([compraImportadaId, identityFingerprint, identityDiscriminator])
  @@index([compraImportadaId])
  @@index([status, createdAt])
  @@index([skuExterno])
}

model MapeamentoMerchantFornecedor {
  id                String                  @id @default(cuid())
  merchantExternoId String
  lojaId            String
  fornecedorId      String
  origem            OrigemMapeamentoExterno @default(MANUAL)
  status            StatusMapeamentoExterno @default(ATIVO)
  version           Int                     @default(1)
  revisadoPorId     String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  merchantExterno MerchantExterno @relation(fields: [merchantExternoId], references: [id], onDelete: Restrict)
  loja            Loja            @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  fornecedor      Fornecedor      @relation(fields: [fornecedorId, lojaId], references: [id, lojaId], onDelete: Restrict)
  revisadoPor     Usuario         @relation(fields: [revisadoPorId], references: [id], onDelete: Restrict)

  @@unique([merchantExternoId, lojaId])
  @@index([lojaId, status])
}

model MapeamentoItemProduto {
  id            String                  @id @default(cuid())
  itemExternoId String
  lojaId        String
  produtoId     String
  origem        OrigemMapeamentoExterno @default(MANUAL)
  status        StatusMapeamentoExterno @default(ATIVO)
  version       Int                     @default(1)
  revisadoPorId String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  itemExterno CompraImportadaItem @relation(fields: [itemExternoId], references: [id], onDelete: Restrict)
  loja        Loja                @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  produto     Produto             @relation(fields: [produtoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  revisadoPor Usuario             @relation(fields: [revisadoPorId], references: [id], onDelete: Restrict)

  @@unique([itemExternoId, lojaId])
  @@index([lojaId, status])
}

model AtribuicaoCompraItem {
  id                      String   @id @default(cuid())
  itemExternoId           String
  lojaId                  String
  quantidade              Int
  quantidadeMaterializada Int      @default(0)
  version                 Int      @default(1)
  atribuidoPorId          String
  motivo                  String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  itemExterno         CompraImportadaItem        @relation(fields: [itemExternoId], references: [id], onDelete: Restrict)
  loja                Loja                       @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  atribuidoPor        Usuario                    @relation(fields: [atribuidoPorId], references: [id], onDelete: Restrict)
  itensMaterializados MaterializacaoCompraItem[]

  @@unique([itemExternoId, lojaId])
  @@unique([id, lojaId])
  @@index([lojaId, updatedAt])
}

model MaterializacaoCompra {
  id                 String                     @id @default(cuid())
  compraImportadaId  String
  lojaId             String
  pedidoCompraId     String                     @unique
  status             StatusMaterializacaoCompra @default(CONCLUIDA)
  snapshot           Json
  materializadoPorId String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  compraImportada  CompraImportada            @relation(fields: [compraImportadaId], references: [id], onDelete: Restrict)
  loja             Loja                       @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  pedidoCompra     PedidoCompra               @relation(fields: [pedidoCompraId, lojaId], references: [id, lojaId], onDelete: Restrict)
  materializadoPor Usuario                    @relation(fields: [materializadoPorId], references: [id], onDelete: Restrict)
  itens            MaterializacaoCompraItem[]

  @@unique([compraImportadaId, lojaId])
  @@unique([pedidoCompraId, lojaId])
  @@unique([id, lojaId])
  @@index([lojaId, createdAt])
}

model MaterializacaoCompraItem {
  id                 String   @id @default(cuid())
  materializacaoId   String
  lojaId             String
  itemExternoId      String
  atribuicaoId       String
  pedidoCompraItemId String   @unique
  quantidade         Int
  produtoSnapshot    Json
  mappingVersion     Int
  createdAt          DateTime @default(now())

  materializacao MaterializacaoCompra @relation(fields: [materializacaoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  itemExterno    CompraImportadaItem  @relation(fields: [itemExternoId], references: [id], onDelete: Restrict)
  atribuicao     AtribuicaoCompraItem @relation(fields: [atribuicaoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  pedidoItem     PedidoCompraItem     @relation(fields: [pedidoCompraItemId], references: [id], onDelete: Restrict)

  @@unique([materializacaoId, itemExternoId])
  @@index([lojaId, itemExternoId])
}

model ConflitoCompra {
  id                String               @id @default(cuid())
  compraImportadaId String
  itemExternoId     String?
  tipo              TipoConflitoCompra
  status            StatusConflitoCompra @default(ABERTO)
  referencia        String
  payloadAnterior   Json?
  payloadNovo       Json?
  resolvidoPorId    String?
  resolvidoEm       DateTime?
  motivoResolucao   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  compraImportada CompraImportada      @relation(fields: [compraImportadaId], references: [id], onDelete: Restrict)
  itemExterno     CompraImportadaItem? @relation(fields: [itemExternoId], references: [id], onDelete: Restrict)
  resolvidoPor    Usuario?             @relation(fields: [resolvidoPorId], references: [id], onDelete: Restrict)

  @@index([compraImportadaId, status])
  @@index([tipo, status])
}

model PedidoCompra {
  id                   String                @id @default(cuid())
  lojaId               String
  fornecedorId         String
  numeroPedido         String
  dataCompra           DateTime
  moeda                String                @default("USD")
  status               PedidoCompraStatus    @default(DRAFT)
  descontoPedido       Decimal               @default(0) @db.Decimal(12, 2)
  frete                Decimal               @default(0) @db.Decimal(12, 2)
  imposto              Decimal               @default(0) @db.Decimal(12, 2)
  subtotal             Decimal               @default(0) @db.Decimal(12, 2)
  total                Decimal               @default(0) @db.Decimal(12, 2)
  observacoes          String?
  canceladoEm          DateTime?
  compraImportadaId    String?
  statusAtribuicao     StatusAtribuicao      @default(PENDENTE_ATRIBUICAO)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  loja                 Loja                  @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  fornecedor           Fornecedor            @relation(fields: [fornecedorId, lojaId], references: [id, lojaId], onDelete: Restrict)
  compraImportada      CompraImportada?      @relation(fields: [compraImportadaId], references: [id], onDelete: SetNull)
  itens                PedidoCompraItem[]
  pagamentos           Pagamento[]
  custo                CustoPedido?
  materializacaoOrigem MaterializacaoCompra?

  @@unique([lojaId, fornecedorId, numeroPedido])
  @@unique([id, lojaId])
  @@index([lojaId, status])
  @@index([lojaId, fornecedorId])
  @@index([lojaId, dataCompra])
  @@index([compraImportadaId])
}

model PedidoCompraItem {
  id                      String                    @id @default(cuid())
  pedidoCompraId          String
  lojaId                  String
  produtoId               String
  quantidade              Int
  quantidadeRecebidaMiami Int                       @default(0)
  precoUnitario           Decimal                   @db.Decimal(12, 2)
  descontoItem            Decimal                   @default(0) @db.Decimal(12, 2)
  totalItem               Decimal                   @db.Decimal(12, 2)
  observacoes             String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  loja                    Loja                      @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  pedido                  PedidoCompra              @relation(fields: [pedidoCompraId, lojaId], references: [id, lojaId], onDelete: Cascade)
  produto                 Produto                   @relation(fields: [produtoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  alocacoesMala           AlocacaoMala[]
  recebimentosMiami       RecebimentoMiami[]
  recebimentoItens        RecebimentoItem[]
  custosRateados          CustoPedidoItem[]
  atribuicoes             AtribuicaoItem[]
  materializacaoOrigem    MaterializacaoCompraItem?

  @@unique([pedidoCompraId, produtoId])
  @@unique([id, lojaId])
  @@index([lojaId, produtoId])
  @@index([lojaId, pedidoCompraId])
}

enum ViagemStatus {
  PLANNED
  OPEN_FOR_ALLOCATION
  CLOSED_FOR_ALLOCATION
  IN_TRANSIT
  ARRIVED_BRAZIL
  CANCELLED
}

enum MalaStatus {
  PLANNING
  CLOSED
  CHECKED_IN
  ARRIVED_BRAZIL
  RECEIVED
  CANCELLED
}

model Viajante {
  id          String   @id @default(cuid())
  lojaId      String
  nome        String
  email       String?
  telefone    String?
  documento   String?
  observacoes String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  loja        Loja     @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagens     Viagem[]

  @@unique([id, lojaId])
  @@index([lojaId, ativo])
}

model Viagem {
  id                      String               @id @default(cuid())
  lojaId                  String
  viajanteId              String
  origem                  String
  destino                 String
  partidaEm               DateTime
  chegadaPrevistaEm       DateTime
  chegadaRealEm           DateTime?
  status                  ViagemStatus         @default(PLANNED)
  periodoEnvio            String               @default("MANHA")
  observacoes             String?
  rotaCodigo              String               @default("LEGACY_MIAMI_PARAGUAI_BRASIL")
  rotaVersao              Int                  @default(1)
  checkpointsObrigatorios String[]             @default(["MIAMI", "PARAGUAI", "BRASIL", "RECEBIMENTO", "ENTRADA_DEFINITIVA"])
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  loja                    Loja                 @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viajante                Viajante             @relation(fields: [viajanteId, lojaId], references: [id, lojaId], onDelete: Restrict)
  malas                   Mala[]
  checkpointsParaguai     CheckpointParaguai[]
  checkpointsBrasil       CheckpointBrasil[]
  estoquesEntradas        EstoqueEntrada[]
  recebimentos            Recebimento[]

  @@unique([id, lojaId])
  @@index([lojaId, status])
  @@index([lojaId, partidaEm])
}

model Mala {
  id                  String               @id @default(cuid())
  lojaId              String
  viagemId            String
  codigo              String
  limitePesoKg        Decimal              @default(23) @db.Decimal(8, 3)
  status              MalaStatus           @default(PLANNING)
  observacoes         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  loja                Loja                 @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagem              Viagem               @relation(fields: [viagemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  volumes             VolumeLogistico[]
  alocacoes           AlocacaoMala[]
  checkpointsParaguai CheckpointParaguai[]
  checkpointsBrasil   CheckpointBrasil[]
  estoquesEntradas    EstoqueEntrada[]
  recebimentos        Recebimento[]

  @@unique([viagemId, codigo])
  @@unique([id, lojaId])
  @@index([lojaId, status])
}

model VolumeLogistico {
  id          String         @id @default(cuid())
  lojaId      String
  malaId      String
  codigo      String
  taraKg      Decimal        @default(0.5) @db.Decimal(8, 3)
  observacoes String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  loja        Loja           @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  mala        Mala           @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Cascade)
  alocacoes   AlocacaoMala[]

  @@unique([malaId, codigo])
  @@unique([id, lojaId])
  @@index([lojaId, malaId])
}

model AlocacaoMala {
  id                 String           @id @default(cuid())
  lojaId             String
  pedidoCompraItemId String
  malaId             String
  volumeLogisticoId  String
  quantidade         Int
  pesoConteudoKg     Decimal          @db.Decimal(10, 3)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  loja               Loja             @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  item               PedidoCompraItem @relation(fields: [pedidoCompraItemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  mala               Mala             @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  volume             VolumeLogistico  @relation(fields: [volumeLogisticoId, lojaId], references: [id, lojaId], onDelete: Restrict)

  @@unique([pedidoCompraItemId, malaId, volumeLogisticoId])
  @@index([lojaId, malaId])
}

model RecebimentoMiami {
  id                 String               @id @default(cuid())
  lojaId             String
  pedidoCompraItemId String
  quantidadeRecebida Int
  recebidoEm         DateTime
  confirmadoPorId    String
  observacao         String?
  atraso             Boolean              @default(false)
  tipoDivergencia    TipoDivergenciaMiami @default(CORRETO)
  createdAt          DateTime             @default(now())
  loja               Loja                 @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  item               PedidoCompraItem     @relation(fields: [pedidoCompraItemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  confirmadoPor      Usuario              @relation(fields: [confirmadoPorId], references: [id], onDelete: Restrict)

  @@index([lojaId, pedidoCompraItemId])
  @@index([lojaId, tipoDivergencia])
}

model CheckpointParaguai {
  id              String                  @id @default(cuid())
  lojaId          String
  viagemId        String
  malaId          String
  confirmadoPorId String
  confirmadoEm    DateTime
  observacao      String?
  tipoDivergencia TipoDivergenciaParaguai @default(CORRETO)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  supersededAt    DateTime?

  loja          Loja    @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagem        Viagem  @relation(fields: [viagemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  mala          Mala    @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  confirmadoPor Usuario @relation(fields: [confirmadoPorId], references: [id], onDelete: Restrict)

  @@index([lojaId, viagemId])
  @@index([lojaId, malaId])
  @@index([lojaId, tipoDivergencia])
}

model CheckpointBrasil {
  id              String                @id @default(cuid())
  lojaId          String
  viagemId        String
  malaId          String
  confirmadoPorId String
  confirmadoEm    DateTime
  observacao      String?
  tipoDivergencia TipoDivergenciaBrasil @default(CORRETO)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  supersededAt    DateTime?

  loja          Loja    @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagem        Viagem  @relation(fields: [viagemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  mala          Mala    @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  confirmadoPor Usuario @relation(fields: [confirmadoPorId], references: [id], onDelete: Restrict)

  @@index([lojaId, viagemId])
  @@index([lojaId, malaId])
  @@index([lojaId, tipoDivergencia])
}

enum RecebimentoStatus {
  PENDING
  IN_PROGRESS
  PARTIALLY_COMPLETED
  COMPLETED
  REJECTED
}

enum EstoqueEntradaStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum TipoDivergenciaMiami {
  CORRETO
  FALTANTE
  QUANTIDADE_DIVERGENTE
  DANIFICADO
  DESCONHECIDO
  TRACKING_NAO_LOCALIZADO
}

enum TipoDivergenciaParaguai {
  CORRETO
  MALA_AUSENTE
  VOLUME_AUSENTE
  ITEM_NAO_LOCALIZADO
  QUANTIDADE_DIVERGENTE
  AVARIA
  ITEM_EXTRA
  CHECKPOINT_PARCIAL
}

enum TipoDivergenciaBrasil {
  CORRETO
  MALA_AUSENTE
  ITEM_NAO_LOCALIZADO
  QUANTIDADE_DIVERGENTE
  AVARIA
  ITEM_EXTRA
  REGISTRO_ADUANEIRO_DIVERGENTE
  LACRE_ROMPIDO
}

enum TipoDivergenciaRecebimento {
  CORRETO
  FALTA
  EXCESSO
  AVARIA
  ITEM_INCORRETO
  OUTRO
}

enum DespesaCategoria {
  PROLABORE
  OPERACIONAL
  REINVESTIMENTO
}

enum MovimentacaoEstoqueTipo {
  ENTRY
  RESERVE
  RELEASE_RESERVATION
  EXIT
  ADJUSTMENT_POSITIVE
  ADJUSTMENT_NEGATIVE
  RETURN_ENTRY
  RETURN_EXIT
}

enum MovimentacaoEstoqueMotivo {
  PURCHASE_RECEIPT
  SALE
  MANUAL_CORRECTION
  DAMAGE
  LOSS
  RETURN
  RESERVATION
  RESERVATION_RELEASE
}

model Recebimento {
  id              String                @id @default(cuid())
  lojaId          String
  viagemId        String
  malaId          String
  status          RecebimentoStatus     @default(PENDING)
  iniciadoEm      DateTime
  concluidoEm     DateTime?
  confirmadoPorId String
  observacoes     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  supersededAt    DateTime?
  loja            Loja                  @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagem          Viagem                @relation(fields: [viagemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  mala            Mala                  @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  confirmadoPor   Usuario               @relation(fields: [confirmadoPorId], references: [id], onDelete: Restrict)
  itens           RecebimentoItem[]
  movimentacoes   MovimentacaoEstoque[]

  @@unique([id, lojaId])
  @@index([lojaId, status])
}

model RecebimentoItem {
  id                      String                     @id @default(cuid())
  lojaId                  String
  recebimentoId           String
  pedidoCompraItemId      String
  produtoId               String
  quantidadeEsperada      Int
  quantidadeRecebida      Int                        @default(0)
  quantidadeRejeitada     Int                        @default(0)
  quantidadeJaIncorporada Int                        @default(0)
  observacoes             String?
  tipoDivergencia         TipoDivergenciaRecebimento @default(CORRETO)
  divergenciaResolvida    Boolean                    @default(true)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  loja                    Loja                       @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  recebimento             Recebimento                @relation(fields: [recebimentoId, lojaId], references: [id, lojaId], onDelete: Cascade)
  pedidoItem              PedidoCompraItem           @relation(fields: [pedidoCompraItemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  produto                 Produto                    @relation(fields: [produtoId, lojaId], references: [id, lojaId], onDelete: Restrict)

  @@unique([recebimentoId, pedidoCompraItemId])
  @@index([lojaId, produtoId])
}

model Estoque {
  id                  String                @id @default(cuid())
  lojaId              String
  produtoId           String
  quantidadeFisica    Int                   @default(0)
  quantidadeReservada Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  loja                Loja                  @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  produto             Produto               @relation(fields: [produtoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  movimentacoes       MovimentacaoEstoque[]

  @@unique([lojaId, produtoId])
  @@unique([id, lojaId])
}

model EstoqueEntrada {
  id              String               @id @default(cuid())
  lojaId          String
  viagemId        String
  malaId          String
  confirmadoPorId String
  confirmadoEm    DateTime
  status          EstoqueEntradaStatus @default(PENDING)
  observacao      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  supersededAt    DateTime?

  loja          Loja    @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  viagem        Viagem  @relation(fields: [viagemId, lojaId], references: [id, lojaId], onDelete: Restrict)
  mala          Mala    @relation(fields: [malaId, lojaId], references: [id, lojaId], onDelete: Restrict)
  confirmadoPor Usuario @relation(fields: [confirmadoPorId], references: [id], onDelete: Restrict)

  @@index([lojaId, viagemId])
  @@index([lojaId, malaId])
  @@index([lojaId, status])
}

model MovimentacaoEstoque {
  id                  String                    @id @default(cuid())
  lojaId              String
  produtoId           String
  estoqueId           String
  recebimentoId       String?
  tipo                MovimentacaoEstoqueTipo
  motivo              MovimentacaoEstoqueMotivo
  quantidade          Int
  quantidadeAnterior  Int
  quantidadePosterior Int
  responsavelId       String
  observacoes         String?
  movimentoOriginalId String?
  createdAt           DateTime                  @default(now())
  loja                Loja                      @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  produto             Produto                   @relation(fields: [produtoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  estoque             Estoque                   @relation(fields: [estoqueId, lojaId], references: [id, lojaId], onDelete: Restrict)
  recebimento         Recebimento?              @relation(fields: [recebimentoId, lojaId], references: [id, lojaId], onDelete: Restrict)
  responsavel         Usuario                   @relation(fields: [responsavelId], references: [id], onDelete: Restrict)
  movimentoOriginal   MovimentacaoEstoque?      @relation("MovimentoCompensacao", fields: [movimentoOriginalId, lojaId], references: [id, lojaId], onDelete: Restrict)
  compensacoes        MovimentacaoEstoque[]     @relation("MovimentoCompensacao")

  @@unique([id, lojaId])
  @@index([lojaId, produtoId, createdAt])
  @@index([lojaId, tipo])
  @@index([movimentoOriginalId])
}

enum PagamentoStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum FormaPagamento {
  CREDIT_CARD
  PAYPAL
  BANK_TRANSFER
  CASH
  OTHER
}

model CotacaoCambio {
  id            String        @id @default(cuid())
  lojaId        String
  moedaOrigem   String
  moedaDestino  String
  valorMercado  Decimal       @db.Decimal(18, 6)
  margem        Decimal       @default(0.20) @db.Decimal(18, 6)
  valor         Decimal       @db.Decimal(18, 6)
  cotadoEm      DateTime
  responsavelId String
  createdAt     DateTime      @default(now())
  loja          Loja          @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  responsavel   Usuario       @relation(fields: [responsavelId], references: [id], onDelete: Restrict)
  custos        CustoPedido[]

  @@unique([id, lojaId])
  @@index([lojaId, cotadoEm])
}

model Despesa {
  id          String           @id @default(cuid())
  lojaId      String
  categoria   DespesaCategoria
  descricao   String
  valor       Decimal          @db.Decimal(12, 2)
  dataDespesa DateTime
  observacoes String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  loja        Loja             @relation(fields: [lojaId], references: [id], onDelete: Restrict)

  @@unique([id, lojaId])
  @@index([lojaId, categoria])
  @@index([lojaId, dataDespesa])
}

model Pagamento {
  id             String          @id @default(cuid())
  lojaId         String
  pedidoCompraId String
  formaPagamento FormaPagamento
  moeda          String
  valor          Decimal         @db.Decimal(12, 2)
  status         PagamentoStatus
  pagoEm         DateTime?
  referencia     String?
  observacoes    String?
  estornoDeId    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  loja           Loja            @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  pedido         PedidoCompra    @relation(fields: [pedidoCompraId, lojaId], references: [id, lojaId], onDelete: Restrict)

  @@unique([id, lojaId])
  @@index([lojaId, pedidoCompraId, status])
}

model CustoPedido {
  id              String            @id @default(cuid())
  lojaId          String
  pedidoCompraId  String
  cotacaoCambioId String?
  iofPercentual   Decimal           @default(0) @db.Decimal(8, 6)
  iofValor        Decimal           @default(0) @db.Decimal(12, 2)
  taxas           Decimal           @default(0) @db.Decimal(12, 2)
  custoAdicional  Decimal           @default(0) @db.Decimal(12, 2)
  totalGlobal     Decimal           @default(0) @db.Decimal(12, 2)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  loja            Loja              @relation(fields: [lojaId], references: [id], onDelete: Restrict)
  pedido          PedidoCompra      @relation(fields: [pedidoCompraId, lojaId], references: [id, lojaId], onDelete: Restrict)
  cotacaoCambio   CotacaoCambio?    @relation(fields: [cotacaoCambioId, lojaId], references: [id, lojaId], onDelete: Restrict)
  itens           CustoPedidoItem[]

  @@unique([pedidoCompraId, lojaId])
  @@unique([id, lojaId])
  @@index([lojaId, pedidoCompraId])
}

model CustoPedidoItem {
  id                 String           @id @default(cuid())
  lojaId             String
  custoPedidoId      String
  pedidoCompraItemId String
  custoRateado       Decimal          @db.Decimal(12, 2)
  custoTotalUnitario Decimal          @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  custo              CustoPedido      @relation(fields: [custoPedidoId, lojaId], references: [id, lojaId], onDelete: Cascade)
  pedidoItem         PedidoCompraItem @relation(fields: [pedidoCompraItemId, lojaId], references: [id, lojaId], onDelete: Restrict)

  @@unique([custoPedidoId, pedidoCompraItemId])
  @@index([lojaId, pedidoCompraItemId])
}

enum SimulacaoRisco {
